# Environment variables for the Hostinger deploy (docker-compose.hostinger.yml).
# Set these in Hostinger's deploy form, or create a .env next to the compose
# file if you deploy from the VPS Terminal.
#
# REQUIRED (no safe defaults):
POSTGRES_PASSWORD=change-me-strong-db-password
JWT_SECRET=change-me-run-node-crypto-randomBytes-48-hex
ADMIN_PASSWORD=change-me-admin-login-password
# The public hostname that points at this VPS. Caddy issues HTTPS for it.
# Your VPS hostname (e.g. srv1463162.hstgr.cloud) works, or a custom domain.
DOMAIN=your-host.example.com

# OPTIONAL (sensible defaults already baked into the compose):
POSTGRES_USER=unlikely
POSTGRES_DB=unlikelyland
ADMIN_USERNAME=admin
# Leave AI off until you have an Ollama endpoint reachable from the VPS.
AI_ENABLED=false
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3.1:8b
# CORS_ORIGINS=        # only needed for the native Android app origin later
