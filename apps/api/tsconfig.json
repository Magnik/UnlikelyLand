{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "outDir": "dist",
    "baseUrl": ".",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictPropertyInitialization": false,
    "useDefineForClassFields": false,
    "declaration": false,
    "sourceMap": true
  },
  "include": ["src/**/*.ts", "prisma/seed.ts"],
  "exclude": ["dist", "node_modules"]
}
