// UnlikelyLand database schema.
//
// MVP-active models are fully wired into services. Models for later milestones
// (market, social graph, guilds, prestige, AI item review) are included now so
// the schema anticipates them and migrations stay additive. Enum-like columns
// are stored as String and validated by zod at the API boundary, keeping value
// sets evolvable without an enum migration each time.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  displayName  String
  passwordHash String
  role         String   @default("player") // player | moderator | admin
  // Moderation: a banned user's JWT is rejected by AuthGuard regardless of expiry.
  bannedAt     DateTime?
  bannedReason String?
  // Bumped on logout/ban to invalidate every outstanding access + refresh token
  // (the access token carries this version and AuthGuard rejects a stale one).
  tokenVersion Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  character         Character?
  moderationActions ModerationAction[] @relation("moderationActor")
}

// ── Character ────────────────────────────────────────────────────────────────

model Character {
  id          String  @id @default(uuid())
  userId      String  @unique
  displayName String
  bio         String  @default("")

  level Int @default(1)
  xp    Int @default(0)

  // Lifetime count of combat encounters won (server-incremented; leaderboard input).
  combatVictories Int @default(0)
  // Optional selected cosmetic title (an unlocked public achievement key), shown
  // on the public profile. Null = no title displayed.
  title String?
  // Moderation state. mutedUntil blocks chat/mail send while in the future.
  mutedUntil   DateTime?
  warningCount Int       @default(0)
  // Opt out of appearing on public leaderboards.
  hiddenFromLeaderboards Boolean @default(false)

  // Currencies (see CURRENCY_LABEL in contracts): normal=Clams, premium=Escape
  // Tokens, crafting=Oddments, reputation=Notoriety.
  normalMoney       Int @default(25)
  premiumMoney      Int @default(0)
  craftingResources Int @default(0)
  reputation        Int @default(0)

  staminaCurrent       Int      @default(100)
  staminaMax           Int      @default(100)
  staminaLastUpdatedAt DateTime @default(now())

  regionSetId           String
  contentRating         String  @default("pg13") // family | pg13 | r
  // Legacy free-form field (kept for back-compat; no longer read). Structured
  // preferences live in storyStyleTags as a JSON array of StoryStyleTag values.
  storyStylePreferences String  @default("")
  storyStyleTags        String  @default("[]") // JSON array of StoryStyleTag

  // Death state
  isDead              Boolean   @default(false)
  deathStartedAt      DateTime?
  reviveAvailableAt   DateTime?
  deathReason         String?
  freeReviveAvailable Boolean   @default(false)
  deathCount          Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  regionSet RegionSet       @relation(fields: [regionSetId], references: [id])
  stats     CharacterStats?

  expeditions      Expedition[]
  encounters       Encounter[]
  memories         StoryMemory[]
  npcs             NpcRecord[]
  inventory        InventoryItem[]
  transactions     EconomyTransaction[]
  deaths           DeathRecord[]
  achievements     CharacterAchievement[]
  chatMessages     ChatMessage[]
  listings         MarketListing[]        @relation("seller")
  purchases        MarketListing[]        @relation("buyer")
  conceptsProposed PendingItemConcept[]
  guildMembership  GuildMember?
  guildsOwned      Guild[]                @relation("guildOwner")
  escapes          EscapeRecord[]
  aiLogs           AiGenerationLog[]
  sentMail         MailMessage[]          @relation("mailSender")
  receivedMail     MailMessage[]          @relation("mailRecipient")
  reportsFiled     MessageReport[]        @relation("reporter")
  activityEvents   ActivityEvent[]
  // Social graph back-relations (give the loose join tables real FKs so deleting a
  // character cascades its friend requests/friendships/blocks instead of orphaning).
  friendReqSent    FriendRequest[]        @relation("friendReqFrom")
  friendReqRecvd   FriendRequest[]        @relation("friendReqTo")
  friendshipsA     Friendship[]           @relation("friendshipA")
  friendshipsB     Friendship[]           @relation("friendshipB")
  blocksMade       BlockedUser[]          @relation("blocker")
  blocksAgainst    BlockedUser[]          @relation("blockedTarget")

  @@index([level])
  @@index([reputation])
  @@index([normalMoney])
  @@index([combatVictories])
}

model CharacterStats {
  id          String @id @default(uuid())
  characterId String @unique

  // combat
  strength  Int @default(5)
  agility   Int @default(5)
  toughness Int @default(5)
  accuracy  Int @default(5)
  defense   Int @default(5)
  // social
  charisma     Int @default(5)
  intimidation Int @default(5)
  deception    Int @default(5)
  empathy      Int @default(5)
  negotiation  Int @default(5)
  // personality
  weirdness Int @default(5)
  bravery   Int @default(5)
  caution   Int @default(5)
  curiosity Int @default(5)
  mischief  Int @default(5)
  honor     Int @default(5)

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

// ── World ────────────────────────────────────────────────────────────────────

model RegionSet {
  id    String @id @default(uuid())
  key   String @unique
  name  String
  blurb String @default("")
  order Int    @default(0)

  regions    Region[]
  characters Character[]
}

model Region {
  id          String @id @default(uuid())
  regionSetId String
  name        String
  blurb       String @default("")

  regionSet RegionSet @relation(fields: [regionSetId], references: [id], onDelete: Cascade)
}

// ── Expeditions & encounters ─────────────────────────────────────────────────

model Expedition {
  id             String    @id @default(uuid())
  characterId    String
  type           String // explore | fight | scavenge | socialize | investigate | train | work
  status         String    @default("active") // active | completed | abandoned | failed
  step           Int       @default(0)
  maxSteps       Int
  staminaPerStep Int
  summary        String?
  // Narrative framing chosen once at start (templated per type + locked region) so
  // every step of the expedition shares one premise/goal/place instead of drifting.
  premise        String?
  goal           String?
  regionName     String?
  startedAt      DateTime  @default(now())
  endedAt        DateTime?

  character  Character   @relation(fields: [characterId], references: [id], onDelete: Cascade)
  encounters Encounter[]

  @@index([characterId, status])
}

model Encounter {
  id            String  @id @default(uuid())
  characterId   String
  expeditionId  String?
  regionSetId   String
  source        String // ai | fallback
  encounterType String
  // The full validated encounter.v1 payload (title, description, choices, ...).
  payload       Json
  resolved      Boolean @default(false)
  resolvedChoiceId String?
  // Outcome snapshot (narrative, check, combat, rewards) once resolved.
  resolution    Json?
  // Idempotency: a client-supplied id makes double-submit a no-op.
  clientRequestId String?

  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  character  Character   @relation(fields: [characterId], references: [id], onDelete: Cascade)
  expedition Expedition? @relation(fields: [expeditionId], references: [id], onDelete: SetNull)

  @@unique([characterId, clientRequestId])
  @@index([characterId, resolved])
}

// ── Story memory & NPCs ──────────────────────────────────────────────────────

model StoryMemory {
  id          String   @id @default(uuid())
  characterId String
  memoryType  String
  content     String
  importance  Int      @default(1)
  regionSetId String?
  npcId       String?
  createdAt   DateTime @default(now())

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId, importance])
}

model NpcRecord {
  id             String   @id @default(uuid())
  characterId    String? // owner for private NPCs; null once global
  name           String
  description    String   @default("")
  role           String   @default("")
  status         String   @default("private") // private | shared_candidate | shared | global
  regionSetId    String?
  referenceCount Int      @default(1)
  createdAt      DateTime @default(now())

  character Character? @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([status])
}

// ── Items & economy ──────────────────────────────────────────────────────────

model ItemDefinition {
  id            String   @id @default(uuid())
  key           String   @unique
  name          String
  description   String   @default("")
  slot          String // weapon | armor | tool | trinket | consumable | companion
  rarity        String // common | uncommon | rare | epic | legendary | absurd
  statModifiers Json     @default("{}")
  powerBudget   Int      @default(0)
  // Consumable mechanics (server-interpreted). type: stamina | none.
  consumableEffectType  String @default("none")
  consumableEffectPower Int    @default(0)
  source        String   @default("seed") // seed | ai_approved | admin
  createdAt     DateTime @default(now())

  inventory InventoryItem[]
  listings  MarketListing[]
}

model InventoryItem {
  id               String   @id @default(uuid())
  characterId      String
  itemDefinitionId String
  quantity         Int      @default(1)
  equipped         Boolean  @default(false)
  acquiredAt       DateTime @default(now())

  character      Character      @relation(fields: [characterId], references: [id], onDelete: Cascade)
  itemDefinition ItemDefinition @relation(fields: [itemDefinitionId], references: [id])

  @@index([characterId])
}

model PendingItemConcept {
  id                    String   @id @default(uuid())
  proposedByCharacterId String?
  name                  String
  description           String   @default("")
  intendedRarity        String
  intendedSlot          String
  narrativePurpose      String   @default("")
  status                String   @default("pending") // pending | approved | rejected | auto_approved
  reviewNotes           String?
  createdItemId         String?
  // Server-computed validation verdict captured at ingest time. The AI never
  // supplies stat numbers — the server derives a balanced, budget-capped block.
  proposedStatModifiers Json     @default("{}")
  proposedPowerBudget   Int      @default(0)
  autoApprovable        Boolean  @default(false)
  validationIssues      String   @default("[]") // JSON array of issue strings
  createdAt             DateTime @default(now())

  proposedBy Character? @relation(fields: [proposedByCharacterId], references: [id], onDelete: SetNull)

  @@index([status])
}

model EconomyTransaction {
  id          String   @id @default(uuid())
  characterId String
  currency    String // normal | premium | crafting | reputation | xp
  amount      Int // signed
  reason      String
  refType     String?
  refId       String?
  createdAt   DateTime @default(now())

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId, createdAt])
}

model MarketListing {
  id                String    @id @default(uuid())
  sellerCharacterId String
  itemDefinitionId  String
  quantity          Int       @default(1)
  priceCurrencyType String    @default("normal")
  priceAmount       Int
  status            String    @default("active") // active | sold | cancelled | expired
  buyerCharacterId  String?
  createdAt         DateTime  @default(now())
  expiresAt         DateTime?
  soldAt            DateTime?

  seller         Character      @relation("seller", fields: [sellerCharacterId], references: [id], onDelete: Cascade)
  buyer          Character?     @relation("buyer", fields: [buyerCharacterId], references: [id], onDelete: SetNull)
  itemDefinition ItemDefinition @relation(fields: [itemDefinitionId], references: [id])

  @@index([status])
  // Unindexed FKs cause slow scans (and block ItemDefinition deletes); index the
  // item FK and the seller column used by the "my listings" query.
  @@index([itemDefinitionId])
  @@index([sellerCharacterId])
}

// ── Social ───────────────────────────────────────────────────────────────────

model ChatMessage {
  id          String   @id @default(uuid())
  characterId String
  // Channel routing. channelType: global | region | guild | system. region/guild
  // scope is keyed by the nullable ids below. `channel` is the legacy column kept
  // for back-compat (always 'global' for old rows).
  channel     String   @default("global")
  channelType String   @default("global")
  regionSetId String?
  guildId     String?
  body        String
  // Moderation. moderationStatus: visible | hidden | removed. `deleted` is the
  // legacy boolean kept in sync (removed/hidden => deleted=true) for old readers.
  moderationStatus String   @default("visible")
  reportCount      Int      @default(0)
  deleted          Boolean  @default(false)
  deletedAt        DateTime?
  deletedByUserId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([channel, createdAt])
  @@index([channelType, moderationStatus, createdAt])
  // Guild/region channel reads filter by these ids; without an index they scan the table.
  @@index([guildId, createdAt])
  @@index([regionSetId, createdAt])
}

model MailMessage {
  id                   String    @id @default(uuid())
  senderCharacterId    String
  recipientCharacterId String
  subject              String    @default("")
  body                 String
  readAt               DateTime?
  deletedBySender      Boolean   @default(false)
  deletedByRecipient   Boolean   @default(false)
  // Moderation. moderationStatus: visible | removed (hidden by staff after a report).
  moderationStatus     String    @default("visible")
  reportCount          Int       @default(0)
  createdAt            DateTime  @default(now())

  sender    Character @relation("mailSender", fields: [senderCharacterId], references: [id], onDelete: Cascade)
  recipient Character @relation("mailRecipient", fields: [recipientCharacterId], references: [id], onDelete: Cascade)

  @@index([recipientCharacterId, createdAt])
  @@index([senderCharacterId, createdAt])
}

model FriendRequest {
  id              String   @id @default(uuid())
  fromCharacterId String
  toCharacterId   String
  status          String   @default("pending") // pending | accepted | rejected
  createdAt       DateTime @default(now())

  fromCharacter Character @relation("friendReqFrom", fields: [fromCharacterId], references: [id], onDelete: Cascade)
  toCharacter   Character @relation("friendReqTo", fields: [toCharacterId], references: [id], onDelete: Cascade)

  @@unique([fromCharacterId, toCharacterId])
  // Incoming-request lookups query by recipient; the unique above only indexes the
  // (from, to) prefix, so add a dedicated index on the recipient column.
  @@index([toCharacterId])
}

model Friendship {
  id           String   @id @default(uuid())
  characterAId String
  characterBId String
  createdAt    DateTime @default(now())

  characterA Character @relation("friendshipA", fields: [characterAId], references: [id], onDelete: Cascade)
  characterB Character @relation("friendshipB", fields: [characterBId], references: [id], onDelete: Cascade)

  @@unique([characterAId, characterBId])
  // Friendship lookups also query by the B side (OR characterBId), uncovered by the unique prefix.
  @@index([characterBId])
}

model BlockedUser {
  id                 String   @id @default(uuid())
  characterId        String
  blockedCharacterId String
  createdAt          DateTime @default(now())

  blocker Character @relation("blocker", fields: [characterId], references: [id], onDelete: Cascade)
  blocked Character @relation("blockedTarget", fields: [blockedCharacterId], references: [id], onDelete: Cascade)

  @@unique([characterId, blockedCharacterId])
  // Block feed-filtering queries the reverse direction (blockedCharacterId).
  @@index([blockedCharacterId])
}

// ── Moderation & reporting ───────────────────────────────────────────────────

// A player-filed report against a chat message, mail, profile, or guild. One
// report per (reporter, target) is enforced for message targets so the same user
// cannot inflate the report count by re-reporting.
model MessageReport {
  id                String    @id @default(uuid())
  reporterCharacterId String
  targetType        String // chat | mail | profile | guild
  targetMessageId   String? // ChatMessage/MailMessage id when targetType is chat/mail
  targetCharacterId String? // reported character (profile, or message author)
  targetGuildId     String?
  reason            String // spam | harassment | hate_or_discrimination | sexual_content | threats | scam_or_phishing | other
  note              String    @default("")
  status            String    @default("open") // open | reviewing | actioned | dismissed
  resolvedByUserId  String?
  resolutionNote    String?
  resolvedAt        DateTime?
  createdAt         DateTime  @default(now())

  reporter Character @relation("reporter", fields: [reporterCharacterId], references: [id], onDelete: Cascade)

  @@unique([reporterCharacterId, targetType, targetMessageId])
  @@index([status, createdAt])
  @@index([targetCharacterId])
}

// Append-only audit trail of every privileged moderation/admin action. Never
// exposed to regular players. metadata holds action-specific context as JSON.
model ModerationAction {
  id                String   @id @default(uuid())
  moderatorUserId   String
  actionType        String // hide_message | delete_message | restore_message | mute | unmute | warn | ban | unban | guild_disband | guild_rename | resolve_report | promote | demote | transfer_owner
  targetType        String   @default("") // chat | mail | character | guild | report
  targetCharacterId String?
  targetMessageId   String?
  targetGuildId     String?
  targetReportId    String?
  reason            String   @default("")
  metadata          Json     @default("{}")
  createdAt         DateTime @default(now())

  moderator User @relation("moderationActor", fields: [moderatorUserId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([targetCharacterId])
  @@index([moderatorUserId])
}

// ── Public activity feed ─────────────────────────────────────────────────────

// A public, intentionally-shareable milestone (achievement unlock, level
// milestone, guild join/found, escape). Contains only public-safe text; never
// private story/encounter/economy detail. Drives the world activity feed.
model ActivityEvent {
  id          String   @id @default(uuid())
  characterId String
  type        String // achievement | level | guild | escape | victory
  title       String
  detail      String   @default("")
  createdAt   DateTime @default(now())

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([characterId, createdAt])
}

// ── Guilds ───────────────────────────────────────────────────────────────────

model Guild {
  id               String   @id @default(uuid())
  name             String   @unique
  // Short clan tag (2-5 chars, A-Z0-9) shown next to member names in chat. Unique,
  // nullable so existing guilds backfill cleanly until renamed.
  tag              String?  @unique
  description      String   @default("")
  ownerCharacterId String
  // Guild progression. The bank holds Oddments (crafting currency) deposited by
  // members; xp accrues from contributions and drives a derived guild level.
  bankBalance      Int      @default(0)
  xp               Int      @default(0)
  createdAt        DateTime @default(now())

  // Deleting the founder's character disbands the guild (members already cascade),
  // instead of the previous RESTRICT which made the owner's account undeletable.
  owner   Character     @relation("guildOwner", fields: [ownerCharacterId], references: [id], onDelete: Cascade)
  members GuildMember[]
}

model GuildMember {
  id          String   @id @default(uuid())
  guildId     String
  characterId String   @unique
  role        String   @default("member") // owner | officer | member
  joinedAt    DateTime @default(now())

  guild     Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([guildId])
}

// ── Achievements ─────────────────────────────────────────────────────────────

model Achievement {
  id          String  @id @default(uuid())
  key         String  @unique
  name        String
  description String  @default("")
  isPublic    Boolean @default(true)

  unlocks CharacterAchievement[]
}

model CharacterAchievement {
  id            String   @id @default(uuid())
  characterId   String
  achievementId String
  unlockedAt    DateTime @default(now())

  character   Character   @relation(fields: [characterId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([characterId, achievementId])
}

// ── AI ───────────────────────────────────────────────────────────────────────

model AiGenerationLog {
  id              String   @id @default(uuid())
  characterId     String?
  kind            String   @default("encounter")
  provider        String
  model           String
  latencyMs       Int      @default(0)
  outcome         String // ok | invalid_schema | unsafe | timeout | error | fallback
  validationError String?
  rawResponse     String? // dev/admin-only raw output for debugging
  createdAt       DateTime @default(now())

  character Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)

  @@index([outcome, createdAt])
}

model AiSettings {
  id            String   @id @default("singleton")
  enabled       Boolean  @default(true)
  forceFallback Boolean  @default(false)
  baseUrl       String
  model         String
  timeoutMs     Int      @default(25000)
  updatedAt     DateTime @updatedAt
}

// ── Death & prestige ─────────────────────────────────────────────────────────

model DeathRecord {
  id                  String    @id @default(uuid())
  characterId         String
  reason              String
  diedAt              DateTime  @default(now())
  revivedAt           DateTime?
  method              String? // wait | pay | free
  freeReviveAvailable Boolean   @default(false)

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId])
}

// Prestige / escape — schema present, not implemented in MVP.
model EscapeRecord {
  id          String   @id @default(uuid())
  characterId String
  escapeCount Int      @default(1)
  legacyLevel Int      @default(0)
  summary     String   @default("")
  createdAt   DateTime @default(now())

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  // Makes an escape a one-shot: two concurrent escapes compute the same escapeCount,
  // so the second insert violates this unique and its transaction rolls back,
  // preventing a doubled legacy stat bonus / token grant.
  @@unique([characterId, escapeCount])
}
