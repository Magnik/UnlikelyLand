# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
# Public domain for production (Caddy obtains HTTPS certificates for this)
DOMAIN=play.example.com
ACME_EMAIL=you@example.com

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=unlikely
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=unlikelyland
# API connection string. Host is `postgres` inside Docker Compose, `localhost` for local dev.
DATABASE_URL=postgresql://unlikely:change-me-strong-password@localhost:5432/unlikelyland?schema=public

# ── Redis (reserved for chat pub/sub + BullMQ jobs in Milestone 3+) ──────────
REDIS_URL=redis://redis:6379

# ── API ──────────────────────────────────────────────────────────────────────
API_PORT=4000
# Secret for signing session JWTs.
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=dev-secret-change-me-in-production
JWT_EXPIRES_IN=30d
# Comma-separated extra allowed CORS origins (the Capacitor app origin later).
# Same-origin browser traffic goes through the Next.js /api proxy and needs no CORS.
CORS_ORIGINS=http://localhost:3000

# ── Web ──────────────────────────────────────────────────────────────────────
# Where the Next.js server proxies /api/* requests (browser stays same-origin).
# Local dev: http://localhost:4000 — Docker Compose: http://api:4000
API_INTERNAL_URL=http://localhost:4000

# ── AI (Ollama-compatible) ───────────────────────────────────────────────────
# Initial values for the AiSettings row; admins can change them at runtime.
AI_ENABLED=true
# From inside Docker, host.docker.internal reaches Ollama on the host machine.
# On a Linux VPS this requires the extra_hosts entry already present in docker-compose.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b
AI_TIMEOUT_MS=25000

# ── Seed (first admin account) ───────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password
