# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
# Public domain for production (Caddy obtains HTTPS certificates for this)
DOMAIN=play.example.com
ACME_EMAIL=you@example.com

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=unlikely
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=unlikelyland
# API connection string. Host is `postgres` inside Docker Compose, `localhost` for local dev.
DATABASE_URL=postgresql://unlikely:change-me-strong-password@localhost:5432/unlikelyland?schema=public

# ── Redis (reserved for multi-instance chat pub/sub + BullMQ jobs) ───────────
REDIS_URL=redis://redis:6379

# ── Tests ────────────────────────────────────────────────────────────────────
# Throwaway Postgres for the integration suite (npm run test:integration). Leave
# unset to skip it. Apply migrations to this DB first (prisma migrate deploy).
# TEST_DATABASE_URL=postgresql://unlikely:change-me@localhost:5432/unlikelyland_test?schema=public

# ── API ──────────────────────────────────────────────────────────────────────
API_PORT=4000
# Secret for signing session JWTs. MUST be a strong, UNIQUE value (>=32 chars) in
# production. The API refuses to boot in production with any value starting with
# "dev-secret-change-me" (including the example below) or shorter than 32 chars —
# this example value is committed in the repo, so leaving it set is a full auth
# compromise. Generate a real one and replace it:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=dev-secret-change-me-in-production
# Access-token lifetime (short-lived; the web client refreshes transparently).
# JWT_EXPIRES_IN is kept as the access-token default for back-compat.
JWT_EXPIRES_IN=30m
# Refresh-token lifetime. Logout/ban bumps a per-user token version to revoke both.
REFRESH_EXPIRES_IN=30d
# Comma-separated extra allowed CORS origins (the Capacitor app origin later).
# Same-origin browser traffic goes through the Next.js /api proxy and needs no CORS.
# In production an EMPTY value means "no cross-origin access" (closed) — credentialed
# wildcard reflection is never enabled. Set this only for a native/non-proxied client.
CORS_ORIGINS=http://localhost:3000

# ── Web ──────────────────────────────────────────────────────────────────────
# Where the Next.js server proxies /api/* requests (browser stays same-origin).
# Local dev: http://localhost:4000 — Docker Compose: http://api:4000
API_INTERNAL_URL=http://localhost:4000

# ── AI (Ollama-compatible) ───────────────────────────────────────────────────
# Initial values for the AiSettings row; admins can change them at runtime.
AI_ENABLED=true
# From inside Docker, host.docker.internal reaches Ollama on the host machine.
# On a Linux VPS this requires the extra_hosts entry already present in docker-compose.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b
AI_TIMEOUT_MS=25000

# ── Seed (first admin account) ───────────────────────────────────────────────
# In production the API refuses to boot while ADMIN_PASSWORD is this default, and
# the seed will NOT create the admin account with it — set a strong password first.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password

# ── Worker (ambient "while-away" Story-Memory events) ────────────────────────
# Safe defaults shown; tune without touching code. Times in milliseconds.
WORKER_TICK_MS=300000            # how often the worker wakes (5 min)
WORKER_ACTIVE_WINDOW_MS=3600000  # only seed events for players active in this window (60 min)
WORKER_EVENT_CHANCE=0.3          # per-tick chance an active player gets an ambient event
